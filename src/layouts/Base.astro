---
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>2026-magazine</title>
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3E%3Crect width='16' height='16' fill='white'/%3E%3C/svg%3E" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=IM+Fell+English:ital@0;1&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      background: #fff;
      font-family: 'DM Mono', monospace;
      color: #111;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }
    a { color: inherit; text-decoration: none; }

    #site-title {
      position: fixed;
      top: 22px;
      right: 32px;
      z-index: 300;
      font-family: 'DM Mono', monospace;
      font-size: 13px;
      font-weight: 500;
      color: #111;
      letter-spacing: 0.01em;
      text-decoration: none;
    }
    #site-title:hover { color: #555; }

    .page-content {
      margin-left: 140px;
      padding-top: 60px;
    }

    /* ARTICLE STYLES - global so they apply to markdown content */
    .article-title {
      font-family: 'DM Mono', monospace;
      font-size: 18px;
      font-weight: 500;
      color: #111;
      line-height: 1.3;
      margin-top: 20px;
      margin-bottom: 6px;
    }

    .body p:first-child {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      font-weight: 300;
      color: #999;
      margin-bottom: 24px;
      line-height: 1.6;
    }

    .body ul, .body ol {
      list-style: none;
      display: block;
      margin: 14px 0;
      padding: 0;
      text-align: center;
    }
    .body ul li, .body ol li {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      font-weight: 300;
      font-style: normal;
      color: #999;
      text-align: center;
      line-height: 1.8;
      list-style: none;
      padding-left: 0;
    }
    .body ul li::marker, .body ol li::marker {
      content: '';
      display: none;
    }
    .body ul li a, .body ol li a {
      color: #999;
      text-decoration: none;
      transition: color 0.15s;
    }
    .body ul li a:hover, .body ol li a:hover {
      color: #ccc;
    }

    @media (max-width: 600px) {
      #site-title { display: none; }
      .page-content { margin-left: 0; padding-top: 0; }

      #site-handwriting {
        top: 14px;
        right: auto;
        left: 50%;
        transform: translateX(-50%);
        height: 12px;
      }
    }

    #site-handwriting {
      position: fixed;
      top: 48px;
      right: 32px;
      height: 14px;
      width: auto;
      pointer-events: none;
      opacity: 0.85;
      z-index: 300;
    }
  </style>
</head>
<body>
  <a id="site-title" href="/">2026-04-24 at 11.56.37</a>
  <img id="site-handwriting" src="/handschrift_clean.png" alt="" aria-hidden="true" />
  <slot />
</body>
</html>
