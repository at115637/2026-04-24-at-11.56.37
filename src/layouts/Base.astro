---
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title ?? '2026-04-24 at 11.56.37'}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=IM+Fell+English:ital@0;1&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      background: #fff;
      font-family: 'DM Mono', monospace;
      color: #111;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }
    a { color: inherit; text-decoration: none; }

    #site-title {
      position: fixed;
      top: 22px;
      right: 32px;
      z-index: 300;
      font-family: 'DM Mono', monospace;
      font-size: 13px;
      font-weight: 500;
      color: #111;
      letter-spacing: 0.01em;
      text-decoration: none;
    }
    #site-title:hover { color: #555; }

    .page-content {
      margin-left: 140px;
      padding-top: 60px;
    }

    /* ARTICLE STYLES - global so they apply to markdown content */
    .article-title {
      font-family: 'DM Mono', monospace;
      font-size: 18px;
      font-weight: 500;
      color: #111;
      line-height: 1.3;
      margin-top: 20px;
      margin-bottom: 6px;
    }

    .body p:first-child {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      font-weight: 300;
      color: #999;
      margin-bottom: 24px;
      line-height: 1.6;
    }

    .body ul, .body ol {
      list-style: none;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      margin: 40px 0;
      padding: 0;
    }
    .body ul li, .body ol li {
      font-family: 'IM Fell English', serif;
      font-size: 16px;
      font-style: italic;
      color: #222;
      text-align: center;
      line-height: 1.5;
      list-style: none;
    }
    .body ul li a, .body ol li a {
      color: #222;
      text-decoration: none;
    }
    .body ul li a:hover, .body ol li a:hover {
      color: #888;
    }

    @media (max-width: 600px) {
      #site-title { display: none; }
      .page-content { margin-left: 0; padding-top: 80px; }
    }
  </style>
</head>
<body>
  <a id="site-title" href="/">2026-04-24 at 11.56.37</a>
  <slot />
</body>
</html>
