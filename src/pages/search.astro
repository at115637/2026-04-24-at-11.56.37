---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
const articles = await getCollection('articles');
const articlesData = articles.map((a) => ({
  slug: a.slug,
  title: a.data.title,
  author: a.data.author ?? '',
}));
---
<Base title="Search">
  <div class="sidebar">
    <ul>
      <li><a data-astro-reload href="/search" class="nav-link active">SEARCH</a></li>
      <li><a data-astro-reload href="/articles" class="nav-link">ARTICLES</a></li>
      <li><a data-astro-reload href="/newsletter" class="nav-link">NEWSLETTER</a></li>
      <li><a data-astro-reload href="/publications" class="nav-link disabled">PUBLICATIONS</a></li>
      <li><a data-astro-reload href="/info" class="nav-link">INFO</a></li>
    </ul>
  </div>
  <div class="mobile-header">
    <a data-astro-reload href="/" class="mobile-logo">2026-04-24 at 11.56.37</a>
    <nav class="mobile-nav">
      <a data-astro-reload href="/search" class="active">SEARCH</a>
      <a data-astro-reload href="/articles">ARTICLES</a>
      <a data-astro-reload href="/newsletter">NEWS.</a>
      <a data-astro-reload href="/publications" class="disabled">PUBL.</a>
      <a data-astro-reload href="/info">INFO</a>
    </nav>
  </div>
  <div class="page-content">
    <section class="search-section">
      <input type="text" id="searchInput" placeholder="search..." autocomplete="off" />
      <div id="results" class="results"></div>
    </section>
  </div>
</Base>
<script define:vars={{ articlesData }}>
  const input = document.getElementById('searchInput');
  const results = document.getElementById('results');
  input.addEventListener('input', () => {
    const q = input.value.toLowerCase().trim();
    results.innerHTML = '';
    if (!q) return;
    // Suche separat in Titel ODER Autor — aber zeige immer nur den Titel
    const matches = articlesData.filter(a => {
      const titleMatch = a.title.toLowerCase().includes(q);
      const authorMatch = a.author && a.author.toLowerCase().includes(q);
      return titleMatch || authorMatch;
    });
    if (!matches.length) {
      results.innerHTML = '<p class="no-results">no results</p>';
      return;
    }
    matches.forEach(a => {
      const el = document.createElement('a');
      el.href = `/articles/${a.slug}`;
      el.className = 'result-item';
      el.setAttribute('data-astro-reload', '');
      el.textContent = a.title;
      // Inline-Styles als zusätzliche Absicherung gegen Browser-Default Link-Styles
      el.style.cssText = 'font-family: "DM Mono", monospace; font-size: 11px; font-weight: 300; color: #111; text-decoration: none; display: block; cursor: pointer; transition: color 0.15s;';
      el.addEventListener('mouseenter', () => { el.style.color = '#aaa'; });
      el.addEventListener('mouseleave', () => { el.style.color = '#111'; });
      results.appendChild(el);
    });
  });
</script>
<style is:global>
  /* Suchergebnis-Items: per JS dynamisch erstellt, brauchen globale Styles */
  a.result-item,
  a.result-item:link,
  a.result-item:visited,
  a.result-item:active {
    font-family: 'DM Mono', monospace !important;
    font-size: 11px !important;
    font-weight: 300 !important;
    color: #111 !important;
    text-decoration: none !important;
    display: block !important;
    transition: color 0.15s !important;
    cursor: pointer !important;
  }
  a.result-item:hover {
    color: #aaa !important;
    text-decoration: none !important;
  }
</style>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  .sidebar { position: fixed; top: 22px; left: 0; width: 140px; padding: 0 24px; z-index: 100; }
  .sidebar ul { list-style: none; display: flex; flex-direction: column; gap: 6px; }
  .nav-link { font-family: 'DM Mono', monospace; font-size: 10px; color: #aaa; text-decoration: none; letter-spacing: 0.06em; display: block; transition: color 0.15s; }
  .nav-link:hover { color: #111; }
  .nav-link.active { color: #111; }
  .nav-link.disabled { color: #ddd; pointer-events: none; }
  .mobile-header { display: none; }
  .search-section { padding: 20px 40px 80px; max-width: 500px; margin: 0 auto; }
  #searchInput { font-family: 'DM Mono', monospace; font-size: 11px; font-weight: 300; color: #111; border: none; border-bottom: 0.5px solid #ddd; outline: none; width: 100%; padding: 8px 0; background: transparent; }
  #searchInput::placeholder { color: #ccc; }
  .results { margin-top: 32px; display: flex; flex-direction: column; gap: 14px; }

  .no-results { font-family: 'DM Mono', monospace; font-size: 10px; color: #ccc; }
  @media (max-width: 600px) {
    .sidebar { display: none; }
    .mobile-header {
      display: block;
      width: 100%;
      padding: 14px 20px 0;
    }
    .mobile-logo {
      font-family: 'DM Mono', monospace;
      font-size: 12px;
      font-weight: 500;
      color: #111;
      text-decoration: none;
      position: fixed;
      top: 14px;
      left: 0;
      right: 0;
      text-align: center;
      z-index: 100;
      background: transparent;
      pointer-events: auto;
    }
    .mobile-nav {
      display: flex;
      justify-content: space-between;
      width: 100%;
      padding: 38px 4px 0;
    }
    .mobile-nav a { font-family: 'DM Mono', monospace; font-size: 9px; color: #aaa; letter-spacing: 0; text-decoration: none; transition: color 0.15s; }
    .mobile-nav a:hover { color: #111; }
    .mobile-nav a.active { color: #111; }
    .mobile-nav a.disabled { color: #e0e0e0; pointer-events: none; }
    .search-section { padding: 20px 20px 60px; }
  }
</style>
