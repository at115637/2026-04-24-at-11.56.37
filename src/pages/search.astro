---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
const articles = await getCollection('articles');
const articlesData = articles.map((a) => ({ slug: a.slug, title: a.data.title, body: a.body }));
---
<Base title="Search">
  <div class="sidebar">
    <ul>
      <li><a data-astro-reload href="/2026-04-24-at-11.56.37/search" class="nav-link active">SEARCH</a></li>
      <li><a data-astro-reload href="/2026-04-24-at-11.56.37/articles" class="nav-link">ARTICLES</a></li>
      <li><a data-astro-reload href="/2026-04-24-at-11.56.37/publications" class="nav-link disabled">PUBLICATIONS</a></li>
      <li><a data-astro-reload href="/2026-04-24-at-11.56.37/info" class="nav-link">INFO</a></li>
    </ul>
  </div>
  <div class="mobile-header">
    <a data-astro-reload href="/2026-04-24-at-11.56.37/" class="mobile-logo">2026-04-24 at 11.56.37</a>
    <nav class="mobile-nav">
      <a data-astro-reload href="/2026-04-24-at-11.56.37/search" class="active">SEARCH</a>
      <a data-astro-reload href="/2026-04-24-at-11.56.37/articles">ARTICLES</a>
      <a data-astro-reload href="/2026-04-24-at-11.56.37/publications" class="disabled">PUBL.</a>
      <a data-astro-reload href="/2026-04-24-at-11.56.37/info">INFO</a>
    </nav>
  </div>
  <div class="page-content">
    <div class="desktop-topbar">
      <a data-astro-reload href="/2026-04-24-at-11.56.37/" class="mag-title">2026-04-24 at 11.56.37</a>
    </div>
    <section class="search-section">
      <input type="text" id="searchInput" placeholder="search..." autocomplete="off" />
      <div id="results" class="results"></div>
    </section>
  </div>
</Base>
<script define:vars={{ articlesData }}>
  const input = document.getElementById('searchInput');
  const results = document.getElementById('results');
  const base = '/2026-04-24-at-11.56.37';
  input.addEventListener('input', () => {
    const q = input.value.toLowerCase().trim();
    results.innerHTML = '';
    if (!q) return;
    const matches = articlesData.filter(a => a.title.toLowerCase().includes(q) || a.body.toLowerCase().includes(q));
    if (!matches.length) { results.innerHTML = '<p class="no-results">no results</p>'; return; }
    matches.forEach(a => {
      const el = document.createElement('a');
      el.href = `${base}/articles/${a.slug}`;
      el.className = 'result-item';
      el.setAttribute('data-astro-reload', '');
      el.textContent = a.title;
      results.appendChild(el);
    });
  });
</script>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  .sidebar { position: fixed; top: 0; left: 0; width: 140px; height: 100vh; padding: 28px 24px; z-index: 100; display: flex; align-items: center; }
  .sidebar ul { list-style: none; display: flex; flex-direction: column; gap: 6px; }
  .nav-link { font-family: 'DM Mono', monospace; font-size: 10px; color: #aaa; text-decoration: none; letter-spacing: 0.06em; display: block; }
  .nav-link:hover { color: #111; }
  .nav-link.active { color: #111; }
  .nav-link.disabled { color: #ddd; pointer-events: none; }
  .mobile-header { display: none; }
  .page-content { margin-left: 140px; }
  .desktop-topbar { position: fixed; top: 0; right: 0; z-index: 200; padding: 22px 32px 0 0; pointer-events: none; }
  .mag-title { font-family: 'DM Mono', monospace; font-size: 13px; font-weight: 500; color: #111; letter-spacing: 0.01em; text-decoration: none; pointer-events: all; }
  .search-section { padding: 20px 40px 80px; max-width: 500px; margin: 0 auto; }
  #searchInput { font-family: 'DM Mono', monospace; font-size: 11px; font-weight: 300; color: #111; border: none; border-bottom: 0.5px solid #ddd; outline: none; width: 100%; padding: 8px 0; background: transparent; }
  #searchInput::placeholder { color: #ccc; }
  .results { margin-top: 32px; display: flex; flex-direction: column; gap: 12px; }
  .result-item { font-family: 'DM Mono', monospace; font-size: 11px; font-weight: 300; color: #111; text-decoration: none; display: block; }
  .result-item:hover { font-style: italic; }
  .no-results { font-family: 'DM Mono', monospace; font-size: 10px; color: #ccc; }
  @media (max-width: 600px) {
    .sidebar { display: none; }
    .page-content { margin-left: 0; }
    .page-content { padding-top: 80px; }
    .desktop-topbar { position: fixed; top: 0; right: 0; z-index: 200; padding: 22px 32px 0 0; pointer-events: none; }
    .mobile-header { display: flex; flex-direction: column; align-items: center; position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: #fff; padding: 14px 20px 10px; width: 100%; }
    .page-content { padding-top: 80px; }
    .mobile-logo { font-family: 'DM Mono', monospace; font-size: 12px; font-weight: 500; color: #111; text-decoration: none; margin-bottom: 10px; }
    .mobile-nav { display: flex; justify-content: center; gap: 16px; width: 100%; }
    .mobile-nav a { font-family: 'DM Mono', monospace; font-size: 9px; color: #aaa; letter-spacing: 0; text-decoration: none; }
    .mobile-nav a.active { color: #111; }
    .mobile-nav a.disabled { color: #e0e0e0; pointer-events: none; }
    .search-section { padding: 20px 20px 60px; }
  }
</style>
