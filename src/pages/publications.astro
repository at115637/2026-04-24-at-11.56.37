---
import Base from '../layouts/Base.astro';
---
<Base title="Publications">
  <div class="layout">
    <nav class="sidebar">
      <ul>
        <li><a href="/2026-04-24-at-11.56.37/articles" class="nav-link">ARTICLES</a></li>
        <li><a href="/2026-04-24-at-11.56.37/publications" class="nav-link active">PUBLICATIONS</a></li>
        <li><a href="/2026-04-24-at-11.56.37/search" class="nav-link">SEARCH</a></li>
        <li><a href="/2026-04-24-at-11.56.37/" class="nav-link">INFO</a></li>
      </ul>
    </nav>
    <main class="main-content">
      <header class="top-header">
        <a href="/2026-04-24-at-11.56.37/" class="mag-title">2026-04-24 at 11.56.37</a>
      </header>
      <section class="empty">
        <p>coming soon</p>
      </section>
    </main>
  </div>
</Base>

<style>
  .layout { display: flex; min-height: 100vh; }
  .sidebar {
    position: fixed;
    top: 0; left: 0;
    width: 140px;
    height: 100vh;
    padding: 28px 24px;
    z-index: 100;
  }
  .sidebar ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 60px;
  }
  .nav-link {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    font-weight: 400;
    color: #aaa;
    text-decoration: none;
    letter-spacing: 0.06em;
    display: block;
  }
  .nav-link:hover { color: #111; }
  .nav-link.active { color: #111; }
  .main-content {
    margin-left: 140px;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .top-header {
    position: sticky;
    top: 0;
    background: #fff;
    width: 100%;
    display: flex;
    justify-content: center;
    padding: 22px 28px 18px;
    z-index: 50;
  }
  .mag-title {
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    font-weight: 500;
    color: #111;
    letter-spacing: 0.01em;
    text-decoration: none;
  }
  .empty {
    padding: 80px 40px;
  }
  .empty p {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: #ddd;
    letter-spacing: 0.06em;
  }
</style>
