---
import Base from '../layouts/Base.astro';
---
<Base title="Newsletter">
  <div class="sidebar">
    <ul>
      <li><a data-astro-reload href="/search" class="nav-link">SEARCH</a></li>
      <li><a data-astro-reload href="/articles" class="nav-link">ARTICLES</a></li>
      <li><a data-astro-reload href="/newsletter" class="nav-link active">NEWSLETTER</a></li>
      <li><a data-astro-reload href="/publications" class="nav-link disabled">PUBLICATIONS</a></li>
      <li><a data-astro-reload href="/info" class="nav-link">INFO</a></li>
    </ul>
  </div>
  <div class="mobile-header">
    <a data-astro-reload href="/" class="mobile-logo">2026-04-24 at 11.56.37</a>
    <nav class="mobile-nav">
      <a data-astro-reload href="/search">SEARCH</a>
      <a data-astro-reload href="/articles">ARTICLES</a>
      <a data-astro-reload href="/newsletter" class="active">NEWS.</a>
      <a data-astro-reload href="/publications" class="disabled">PUBL.</a>
      <a data-astro-reload href="/info">INFO</a>
    </nav>
  </div>

  <div class="page-content">
    <section class="newsletter-section">
      <p class="newsletter-intro">Subscribe to be notified when a new article is published.</p>
      <div class="subscribe-wrap">
        <script async src="https://eocampaign1.com/form/5b51eefc-43cc-11f1-ad77-67a4c0614056.js" data-form="5b51eefc-43cc-11f1-ad77-67a4c0614056"></script>
      </div>
    </section>
  </div>
</Base>

<script is:inline>
  // EmailOctopus "Powered by" Branding nachträglich ausblenden
  (function () {
    const wrap = document.querySelector('.subscribe-wrap');
    if (!wrap) return;
    const hideBranding = () => {
      wrap.querySelectorAll('a[href*="emailoctopus" i]').forEach((a) => {
        a.style.setProperty('display', 'none', 'important');
        if (a.parentElement) {
          a.parentElement.style.setProperty('display', 'none', 'important');
        }
      });
      wrap.querySelectorAll('*').forEach((el) => {
        if (el.children.length === 0 && /powered\s*by/i.test(el.textContent || '')) {
          el.style.setProperty('display', 'none', 'important');
          if (el.parentElement) {
            el.parentElement.style.setProperty('display', 'none', 'important');
          }
        }
      });
    };
    const observer = new MutationObserver(hideBranding);
    observer.observe(wrap, { childList: true, subtree: true });
    hideBranding();
    setTimeout(hideBranding, 500);
    setTimeout(hideBranding, 1500);
    setTimeout(hideBranding, 3000);
  })();
</script>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  /* Sidebar / Navigation */
  .sidebar { position: fixed; top: 22px; left: 0; width: 140px; padding: 0 24px; z-index: 100; }
  .sidebar ul { list-style: none; display: flex; flex-direction: column; gap: 6px; }
  .nav-link {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: #aaa;
    text-decoration: none;
    letter-spacing: 0.06em;
    display: block;
    transition: color 0.15s;
  }
  .nav-link:hover { color: #111; }
  .nav-link.active { color: #111; }
  .nav-link.disabled { color: #ddd; pointer-events: none; }
  .mobile-header { display: none; }

  /* Newsletter-Inhalt */
  .page-content { min-height: calc(100vh - 80px); display: flex; align-items: center; justify-content: center; }
  .newsletter-section {
    max-width: 560px;
    width: 100%;
    padding: 40px;
  }
  .newsletter-intro {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    font-weight: 300;
    color: #999;
    line-height: 1.6;
    margin-bottom: 24px;
  }

  /* EmailOctopus Form-Overrides — eine Zeile, dezent */
  .subscribe-wrap {
    width: 100%;
  }
  .subscribe-wrap :global(form),
  .subscribe-wrap :global([class*="eocampaign"]) {
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
    padding: 0 !important;
    margin: 0 !important;
    font-family: 'DM Mono', monospace !important;
    display: flex !important;
    flex-direction: column !important;
    gap: 18px !important;
  }

  /* Input-Feld — voll breit, mit Unterstrich */
  .subscribe-wrap :global(input[type="email"]) {
    font-family: 'DM Mono', monospace !important;
    font-size: 11px !important;
    font-weight: 300 !important;
    color: #111 !important;
    background: transparent !important;
    border: none !important;
    border-bottom: 0.5px solid #ddd !important;
    border-radius: 0 !important;
    box-shadow: none !important;
    outline: none !important;
    padding: 8px 0 !important;
    width: 100% !important;
    height: auto !important;
    margin: 0 !important;
  }
  .subscribe-wrap :global(input[type="email"]::placeholder) {
    color: #ccc !important;
    font-family: 'DM Mono', monospace !important;
  }

  /* Submit-Button — wie ein Menü-Reiter */
  .subscribe-wrap :global(button[type="submit"]),
  .subscribe-wrap :global(input[type="submit"]) {
    font-family: 'DM Mono', monospace !important;
    font-size: 10px !important;
    font-weight: 300 !important;
    color: #aaa !important;
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
    border-radius: 0 !important;
    padding: 0 !important;
    margin: 0 !important;
    cursor: pointer !important;
    letter-spacing: 0.06em !important;
    transition: color 0.15s !important;
    width: auto !important;
    height: auto !important;
    align-self: flex-start !important;
    text-align: left !important;
  }
  .subscribe-wrap :global(button[type="submit"]:hover),
  .subscribe-wrap :global(input[type="submit"]:hover) {
    color: #111 !important;
    background: transparent !important;
  }

  /* Erfolgsmeldung etc. */
  .subscribe-wrap :global(label),
  .subscribe-wrap :global(p),
  .subscribe-wrap :global(span) {
    font-family: 'DM Mono', monospace !important;
    font-size: 10px !important;
    font-weight: 300 !important;
    color: #aaa !important;
    background: transparent !important;
    margin: 0 !important;
  }

  /* Powered-by-EmailOctopus-Branding ausblenden */
  .subscribe-wrap :global(.octopus-branding),
  .subscribe-wrap :global(.eo-branding),
  .subscribe-wrap :global(.branding),
  .subscribe-wrap :global([class*="powered"]),
  .subscribe-wrap :global([class*="branding"]),
  .subscribe-wrap :global([class*="Powered"]),
  .subscribe-wrap :global([class*="Branding"]),
  .subscribe-wrap :global(a[href*="emailoctopus"]),
  .subscribe-wrap :global(a[href*="EmailOctopus"]) {
    display: none !important;
    visibility: hidden !important;
    height: 0 !important;
    width: 0 !important;
    overflow: hidden !important;
  }

  @media (max-width: 600px) {
    .sidebar { display: none; }
    .mobile-header {
      display: block;
      width: 100%;
      padding: 14px 20px 0;
    }
    .mobile-logo {
      font-family: 'DM Mono', monospace;
      font-size: 12px;
      font-weight: 500;
      color: #111;
      text-decoration: none;
      position: fixed;
      top: 14px;
      left: 0;
      right: 0;
      text-align: center;
      z-index: 100;
      background: transparent;
      pointer-events: auto;
    }
    .mobile-nav {
      display: flex;
      justify-content: space-between;
      width: 100%;
      padding: 38px 4px 0;
    }
    .mobile-nav a {
      font-family: 'DM Mono', monospace;
      font-size: 9px;
      color: #aaa;
      letter-spacing: 0;
      text-decoration: none;
      transition: color 0.15s;
    }
    .mobile-nav a:hover { color: #111; }
    .mobile-nav a.active { color: #111; }
    .mobile-nav a.disabled { color: #e0e0e0; pointer-events: none; }
    .newsletter-section { padding: 20px; }
  }
</style>
