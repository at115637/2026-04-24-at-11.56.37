---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---
<Base title="Articles">
  <div class="sidebar">
    <ul>
      <li><a data-astro-reload href="/search" class="nav-link">SEARCH</a></li>
      <li><a data-astro-reload href="/articles" class="nav-link active">ARTICLES</a></li>
      <li><a data-astro-reload href="/newsletter" class="nav-link">NEWSLETTER</a></li>
      <li><a data-astro-reload href="/publications" class="nav-link disabled">PUBLICATIONS</a></li>
      <li><a data-astro-reload href="/info" class="nav-link">INFO</a></li>
    </ul>
  </div>
  <div class="mobile-header">
    <a data-astro-reload href="/" class="mobile-logo">2026-04-24 at 11.56.37</a>
    <nav class="mobile-nav">
      <a data-astro-reload href="/search">SEARCH</a>
      <a data-astro-reload href="/articles" class="active">ARTICLES</a>
      <a data-astro-reload href="/newsletter">NEWS.</a>
      <a data-astro-reload href="/publications" class="disabled">PUBL.</a>
      <a data-astro-reload href="/info">INFO</a>
    </nav>
  </div>
  <div class="page-content">
    <section class="grid">
      {articles.map((article) => (
        <a data-astro-reload href={`/articles/${article.slug}`} class="article-thumb">
          <img src={article.data.coverImage} alt={article.data.title} loading="lazy" />
          <p class="article-caption">{article.data.title}</p>
        </a>
      ))}
    </section>
  </div>
</Base>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  .sidebar { position: fixed; top: 22px; left: 0; width: 140px; padding: 0 24px; z-index: 100; }
  .sidebar ul { list-style: none; display: flex; flex-direction: column; gap: 6px; }
  .nav-link { font-family: 'DM Mono', monospace; font-size: 10px; color: #aaa; text-decoration: none; letter-spacing: 0.06em; display: block; transition: color 0.15s; }
  /* 2. Menü-Reiter werden beim Hover dunkel */
  .nav-link:hover { color: #111; }
  .nav-link.active { color: #111; }
  .nav-link.disabled { color: #ddd; pointer-events: none; }
  .mobile-header { display: none; }
  .grid { padding: 20px 40px 80px; display: flex; flex-direction: column; align-items: center; gap: 40px; }
  /* 2. Artikel-Thumbnails verhalten sich wie Reiter — dunkler beim Hover */
  .article-thumb { display: block; width: 260px; text-decoration: none; color: inherit; }
  .article-thumb img { width: 260px; height: 260px; object-fit: cover; display: block; transition: opacity 0.2s; }
  .article-thumb:hover img { opacity: 0.7; }
  .article-caption { font-family: 'DM Mono', monospace; font-size: 10px; font-weight: 300; color: #aaa; margin-top: 10px; transition: color 0.15s; }
  .article-thumb:hover .article-caption { color: #111; }

  @media (max-width: 600px) {
    .sidebar { display: none; }
    .mobile-header {
      display: block;
      width: 100%;
      padding: 14px 20px 0;
    }
    .mobile-logo {
      font-family: 'DM Mono', monospace;
      font-size: 12px;
      font-weight: 500;
      color: #111;
      text-decoration: none;
      position: fixed;
      top: 14px;
      left: 0;
      right: 0;
      text-align: center;
      z-index: 100;
      background: transparent;
      pointer-events: auto;
    }
    .mobile-nav {
      display: flex;
      justify-content: space-between;
      width: 100%;
      padding: 38px 4px 0;
    }
    .mobile-nav a { font-family: 'DM Mono', monospace; font-size: 9px; color: #aaa; letter-spacing: 0; text-decoration: none; transition: color 0.15s; }
    .mobile-nav a:hover { color: #111; }
    .mobile-nav a.active { color: #111; }
    .mobile-nav a.disabled { color: #e0e0e0; pointer-events: none; }

    /* 5. Mobile Artikelübersicht:
          - alle Artikel vertikal untereinander, horizontal auf der Mittelachse
          - oberstes Bild ein Stück runter (gleicher Top-Abstand wie auf anderen Seiten) */
    .grid {
      padding: 40px 16px 60px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 28px;
      max-width: none;
      margin: 0 auto;
    }
    .article-thumb {
      width: 50vw;
      max-width: 200px;
    }
    .article-thumb img {
      width: 100%;
      height: auto;
      aspect-ratio: 1 / 1;
    }
    .article-caption { font-size: 9px; margin-top: 6px; line-height: 1.4; text-align: center; }
  }
</style>
