---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await article.render();
---
<Base title={article.data.title}>
  <div class="sidebar">
    <ul>
      <li><a data-astro-reload href="/search" class="nav-link">SEARCH</a></li>
      <li><a data-astro-reload href="/articles" class="nav-link">ARTICLES</a></li>
      <li><a data-astro-reload href="/publications" class="nav-link disabled">PUBLICATIONS</a></li>
      <li><a data-astro-reload href="/info" class="nav-link">INFO</a></li>
    </ul>
  </div>

  <div class="mobile-header">
    <a data-astro-reload href="/" class="mobile-logo">2026-04-24 at 11.56.37</a>
    <nav class="mobile-nav">
      <a data-astro-reload href="/search">SEARCH</a>
      <a data-astro-reload href="/articles">ARTICLES</a>
      <a data-astro-reload href="/publications" class="disabled">PUBL.</a>
      <a data-astro-reload href="/info">INFO</a>
    </nav>
  </div>

  <div class="page-content">
    <article class="article-content">
      <div class="cover-wrap">
        <div class="cover">
          <img src={article.data.coverImage} alt={article.data.title} />
        </div>
        {article.data.imageCredit && (
          <p class="image-credit">{article.data.imageCredit}</p>
        )}
      </div>
      <h1 class="article-title">{article.data.title}</h1>
      <div class="body">
        <Content />
      </div>
    </article>
  </div>
</Base>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&display=swap');

  * { box-sizing: border-box; margin: 0; padding: 0; }

  .sidebar { position: fixed; top: 0; left: 0; width: 140px; height: 100vh; padding: 28px 24px; z-index: 100; display: flex; align-items: center; }
  .sidebar ul { list-style: none; display: flex; flex-direction: column; gap: 6px; }
  .nav-link { font-family: 'DM Mono', monospace; font-size: 10px; color: #aaa; text-decoration: none; letter-spacing: 0.06em; display: block; }
  .nav-link:hover { color: #111; }
  .nav-link.disabled { color: #ddd; pointer-events: none; }

  .mobile-header { display: none; }

  .article-content { max-width: 560px; margin: 0 auto; padding: 20px 40px 100px; }

  .cover-wrap { margin-bottom: 10px; }
  .cover { width: 100%; aspect-ratio: 4/3; overflow: hidden; }
  .cover img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .image-credit { font-family: 'DM Mono', monospace; font-size: 9px; font-weight: 300; color: #bbb; letter-spacing: 0.03em; text-align: right; margin-top: 6px; }

  .article-title { font-family: 'DM Mono', monospace; font-size: 12px; font-weight: 400; color: #111; line-height: 1.7; margin-top: 28px; margin-bottom: 32px; }

  .body { font-family: 'DM Mono', monospace; font-size: 11px; font-weight: 300; color: #444; line-height: 2; }
  .body h1, .body h2, .body h3 { font-size: 12px; font-weight: 400; color: #111; line-height: 1.7; margin-bottom: 24px; }
  .body p { margin-bottom: 20px; }
  .body img { display: none; }
  .body audio, .body video { width: 100%; margin: 32px 0; display: block; }
  .body audio { filter: grayscale(1); }

  .body ol, .body ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    margin: 32px 0;
    padding: 0;
  }
  .body ol li, .body ul li {
    font-family: 'Cormorant Garamond', serif;
    font-size: 15px;
    font-weight: 300;
    font-style: italic;
    color: #333;
    text-align: center;
    letter-spacing: 0.01em;
    line-height: 1.6;
    list-style: none;
  }

  @media (max-width: 600px) {
    .sidebar { display: none; }
    .mobile-header { display: flex; flex-direction: column; align-items: center; position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: #fff; padding: 14px 20px 10px; width: 100%; }
    .mobile-logo { font-family: 'DM Mono', monospace; font-size: 12px; font-weight: 500; color: #111; text-decoration: none; margin-bottom: 10px; }
    .mobile-nav { display: flex; justify-content: center; gap: 16px; width: 100%; }
    .mobile-nav a { font-family: 'DM Mono', monospace; font-size: 9px; color: #aaa; letter-spacing: 0; text-decoration: none; }
    .mobile-nav a.disabled { color: #e0e0e0; pointer-events: none; }
    .article-content { padding: 20px 20px 80px; }
  }
</style>
