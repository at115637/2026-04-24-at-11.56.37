---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const latest = articles[0];
---
<Base>
  <div class="sidebar">
    <ul>
      <li><a data-astro-reload href="/search" class="nav-link">SEARCH</a></li>
      <li><a data-astro-reload href="/articles" class="nav-link">ARTICLES</a></li>
      <li><a data-astro-reload href="/publications" class="nav-link disabled">PUBLICATIONS</a></li>
      <li><a data-astro-reload href="/info" class="nav-link">INFO</a></li>
    </ul>
  </div>

  <div class="mobile-header">
    <a data-astro-reload href="/" class="mobile-logo">2026-04-24 at 11.56.37</a>
    <nav class="mobile-nav">
      <a data-astro-reload href="/search">SEARCH</a>
      <a data-astro-reload href="/articles">ARTICLES</a>
      <a data-astro-reload href="/publications" class="disabled">PUBL.</a>
      <a data-astro-reload href="/info">INFO</a>
    </nav>
  </div>

  <div class="page-content">
    <section class="hero">
      {latest && (
        <a data-astro-reload href={`/articles/${latest.slug}`} class="hero-link">
          <div class="hero-img">
            <img src={latest.data.coverImage} alt={latest.data.title} />
          </div>
        </a>
      )}
      <div class="subscribe-wrap">
        <script async src="https://eocampaign1.com/form/5b51eefc-43cc-11f1-ad77-67a4c0614056.js" data-form="5b51eefc-43cc-11f1-ad77-67a4c0614056"></script>
      </div>
    </section>
  </div>
</Base>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  .sidebar {
    position: fixed;
    top: 22px; left: 0;
    width: 140px;
    padding: 0 24px;
    z-index: 100;
  }
  .sidebar ul { list-style: none; display: flex; flex-direction: column; gap: 6px; }
  .nav-link { font-family: 'DM Mono', monospace; font-size: 10px; color: #aaa; text-decoration: none; letter-spacing: 0.06em; display: block; }
  .nav-link:hover { color: #333; }
  .nav-link.disabled { color: #ddd; pointer-events: none; }

  .mobile-header { display: none; }

  .page-content {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero { width: 100%; display: flex; justify-content: center; padding: 80px 40px 60px; }
  .hero-link { display: block; text-decoration: none; width: 100%; max-width: 700px; }
  .hero-img { width: 100%; aspect-ratio: 4/3; overflow: hidden; }
  .hero-img img { width: 100%; height: 100%; object-fit: cover; display: block; transition: opacity 0.2s; }
  .hero-link:hover img { opacity: 0.8; }

  /* Subscribe-Bereich unter dem Bild */
  .subscribe-wrap {
    width: 100%;
    max-width: 700px;
    margin-top: 20px;
  }

  /* EmailOctopus Form-Overrides — Kasten passend zur Site */
  .subscribe-wrap :global(.eocampaign-form),
  .subscribe-wrap :global(form),
  .subscribe-wrap :global(.eo-form) {
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
    padding: 0 !important;
    font-family: 'DM Mono', monospace !important;
  }

  /* Input-Feld */
  .subscribe-wrap :global(input[type="email"]) {
    font-family: 'DM Mono', monospace !important;
    font-size: 11px !important;
    font-weight: 300 !important;
    color: #111 !important;
    background: transparent !important;
    border: none !important;
    border-bottom: 0.5px solid #ddd !important;
    border-radius: 0 !important;
    box-shadow: none !important;
    outline: none !important;
    padding: 6px 0 !important;
    width: 100% !important;
  }
  .subscribe-wrap :global(input[type="email"]::placeholder) {
    color: #ccc !important;
    font-family: 'DM Mono', monospace !important;
  }

  /* Submit-Button */
  .subscribe-wrap :global(button[type="submit"]),
  .subscribe-wrap :global(input[type="submit"]) {
    font-family: 'DM Mono', monospace !important;
    font-size: 10px !important;
    font-weight: 300 !important;
    color: #aaa !important;
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
    border-radius: 0 !important;
    padding: 6px 0 !important;
    cursor: pointer !important;
    letter-spacing: 0.06em !important;
    transition: color 0.15s !important;
    text-transform: uppercase !important;
  }
  .subscribe-wrap :global(button[type="submit"]:hover),
  .subscribe-wrap :global(input[type="submit"]:hover) {
    color: #111 !important;
    background: transparent !important;
  }

  /* Alle Labels, Texte */
  .subscribe-wrap :global(label),
  .subscribe-wrap :global(p),
  .subscribe-wrap :global(h1),
  .subscribe-wrap :global(h2),
  .subscribe-wrap :global(h3) {
    font-family: 'DM Mono', monospace !important;
    font-size: 10px !important;
    font-weight: 300 !important;
    color: #aaa !important;
  }

  /* Lila "Powered by EmailOctopus" Branding verstecken */
  .subscribe-wrap :global(.branding),
  .subscribe-wrap :global([class*="powered"]),
  .subscribe-wrap :global([class*="branding"]),
  .subscribe-wrap :global(a[href*="emailoctopus"]) {
    display: none !important;
  }

  @media (max-width: 600px) {
    .sidebar { display: none; }
    /* Mobile-Header ist KEIN fixer Block mehr — nur das Logo ist sticky */
    .mobile-header {
      display: block;
      width: 100%;
      padding: 14px 20px 0;
    }
    /* Logo: sticky am Bildschirmrand, transparenter Hintergrund */
    .mobile-logo {
      font-family: 'DM Mono', monospace;
      font-size: 12px;
      font-weight: 500;
      color: #111;
      text-decoration: none;
      position: fixed;
      top: 14px;
      left: 0;
      right: 0;
      text-align: center;
      z-index: 100;
      background: transparent;
      pointer-events: auto;
    }
    /* Menü-Reiter: scrollen mit, breit verteilt */
    .mobile-nav {
      display: flex;
      justify-content: space-between;
      width: 100%;
      padding: 38px 4px 0;
    }
    .mobile-nav a {
      font-family: 'DM Mono', monospace;
      font-size: 9px;
      color: #aaa;
      letter-spacing: 0;
      text-decoration: none;
      transition: color 0.15s;
    }
    .mobile-nav a:hover { color: #111; }
    .mobile-nav a.disabled { color: #e0e0e0; pointer-events: none; }

    /* Inhalt vertikal mittig — Bild zentriert auf dem Screen */
    .page-content {
      min-height: calc(100vh - 80px);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .hero { padding: 0 20px; }
  }
</style>
