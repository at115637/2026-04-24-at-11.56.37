---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const latest = articles[0];
---
<Base>
  <div class="sidebar">
    <ul>
      <li><a data-astro-reload href="/2026-04-24-at-11.56.37/search" class="nav-link">SEARCH</a></li>
      <li><a data-astro-reload href="/2026-04-24-at-11.56.37/articles" class="nav-link">ARTICLES</a></li>
      <li><a data-astro-reload href="/2026-04-24-at-11.56.37/publications" class="nav-link disabled">PUBLICATIONS</a></li>
      <li><a data-astro-reload href="/2026-04-24-at-11.56.37/info" class="nav-link">INFO</a></li>
    </ul>
  </div>

  <div class="mobile-header">
    <a data-astro-reload href="/2026-04-24-at-11.56.37/" class="mobile-logo">2026-04-24 at 11.56.37</a>
    <nav class="mobile-nav">
      <a data-astro-reload href="/2026-04-24-at-11.56.37/search">SEARCH</a>
      <a data-astro-reload href="/2026-04-24-at-11.56.37/articles">ARTICLES</a>
      <a data-astro-reload href="/2026-04-24-at-11.56.37/publications" class="disabled">PUBL.</a>
      <a data-astro-reload href="/2026-04-24-at-11.56.37/info">INFO</a>
    </nav>
  </div>

  <div class="page-content">
    <div class="desktop-topbar">
      <a data-astro-reload href="/2026-04-24-at-11.56.37/" class="mag-title">2026-04-24 at 11.56.37</a>
    </div>
    <section class="hero">
      {latest && (
        <a data-astro-reload href={`/2026-04-24-at-11.56.37/articles/${latest.slug}`} class="hero-link">
          <div class="hero-img">
            <img src={latest.data.coverImage} alt={latest.data.title} />
          </div>
        </a>
      )}
    </section>
  </div>
</Base>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  .sidebar {
    position: fixed;
    top: 0; left: 0;
    width: 140px; height: 100vh;
    padding: 28px 24px;
    z-index: 100;
    display: flex;
    align-items: center;
  }
  .sidebar ul { list-style: none; display: flex; flex-direction: column; gap: 6px; }
  .nav-link { font-family: 'DM Mono', monospace; font-size: 10px; color: #aaa; text-decoration: none; letter-spacing: 0.06em; display: block; }
  .nav-link:hover { color: #111; }
  .nav-link.disabled { color: #ddd; pointer-events: none; }

  .mobile-header { display: none; }

  .page-content {
    margin-left: 140px;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .desktop-topbar {
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    justify-content: flex-end;
    padding: 22px 32px 0 0;
    pointer-events: none;
  }
  .mag-title {
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    font-weight: 500;
    color: #111;
    letter-spacing: 0.01em;
    text-decoration: none;
    pointer-events: all;
  }

  .hero {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px 40px 60px;
  }
  .hero-link { display: block; text-decoration: none; width: 100%; max-width: 560px; }
  .hero-img { width: 100%; aspect-ratio: 4/3; overflow: hidden; }
  .hero-img img { width: 100%; height: 100%; object-fit: cover; display: block; transition: opacity 0.2s; }
  .hero-link:hover img { opacity: 0.85; }

  @media (max-width: 600px) {
    .sidebar { display: none; }
    .page-content { margin-left: 0; padding-top: 80px; min-height: auto; flex-direction: column; }
    .desktop-topbar { display: none; }

    .mobile-header {
      display: flex;
      flex-direction: column;
      align-items: center;
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      background: #fff;
      padding: 14px 20px 10px;
      width: 100%;
    }
    .mobile-logo { font-family: 'DM Mono', monospace; font-size: 12px; font-weight: 500; color: #111; text-decoration: none; margin-bottom: 10px; }
    .mobile-nav { display: flex; justify-content: center; gap: 16px; width: 100%; }
    .mobile-nav a { font-family: 'DM Mono', monospace; font-size: 9px; color: #aaa; letter-spacing: 0; text-decoration: none; }
    .mobile-nav a.active { color: #111; }
    .mobile-nav a.disabled { color: #e0e0e0; pointer-events: none; }

    .hero { padding: 20px 20px 60px; align-items: flex-start; }
  }
</style>
