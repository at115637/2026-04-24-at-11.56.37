---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const latest = articles[0];
---
<Base>
  <div class="layout">
    <nav class="sidebar">
      <ul>
        <li><a href="/2026-04-24-at-11.56.37/articles" class="nav-link">ARTICLES</a></li>
        <li><a href="/2026-04-24-at-11.56.37/publications" class="nav-link disabled">PUBLICATIONS</a></li>
        <li><a href="/2026-04-24-at-11.56.37/search" class="nav-link">SEARCH</a></li>
        <li><a href="/2026-04-24-at-11.56.37/info" class="nav-link">INFO</a></li>
      </ul>
    </nav>

    <main class="main-content">
      <header class="top-header">
        <a href="/2026-04-24-at-11.56.37/" class="mag-title">2026-04-24 at 11.56.37</a>
      </header>

      <section class="hero">
        {latest && (
          <a href={`/2026-04-24-at-11.56.37/articles/${latest.slug}`} class="hero-link">
            <div class="hero-img">
              <img src={latest.data.coverImage} alt={latest.data.title} />
            </div>
            <p class="hero-caption">{latest.data.title}</p>
          </a>
        )}
      </section>
    </main>
  </div>
</Base>

<style>
  .layout { display: flex; min-height: 100vh; }
  .sidebar {
    position: fixed;
    top: 0; left: 0;
    width: 140px;
    height: 100vh;
    padding: 28px 24px;
    z-index: 100;
    display: flex;
    align-items: center;
  }
  .sidebar ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .nav-link {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    font-weight: 400;
    color: #aaa;
    text-decoration: none;
    letter-spacing: 0.06em;
    display: block;
  }
  .nav-link:hover { color: #111; }
  .nav-link.disabled { color: #ddd; cursor: default; pointer-events: none; }
  .main-content {
    margin-left: 140px;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .top-header {
    position: sticky;
    top: 0;
    background: #fff;
    width: 100%;
    display: flex;
    justify-content: center;
    padding: 22px 28px 18px;
    z-index: 50;
  }
  .mag-title {
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    font-weight: 500;
    color: #111;
    letter-spacing: 0.01em;
    text-decoration: none;
  }
  .hero {
    padding: 40px 40px 80px;
    width: 100%;
    max-width: 700px;
  }
  .hero-link { display: block; text-decoration: none; }
  .hero-img {
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
    margin-bottom: 16px;
  }
  .hero-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.2s ease;
  }
  .hero-link:hover .hero-img img { opacity: 0.85; }
  .hero-caption {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    font-weight: 300;
    color: #aaa;
    letter-spacing: 0.03em;
  }
</style>
